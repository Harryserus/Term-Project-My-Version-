<%- include("../partials/client-header.ejs", { title: "My Orders" }) %>

<!-- Optional: reuse the same modal CSS used in admin so it looks identical -->
<link rel="stylesheet" href="/css/adminOrderModal.css" />

<div class="orders-container">
  <% if (!orders || orders.length === 0) { %>
    <div class="order-card">
      <div class="order-header">
        <div class="order-number">No orders yet</div>
        <div class="order-date">Buy a game to see it here.</div>
      </div>

      <a class="order-view-link" href="/customer">Go to store</a>
    </div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <%
        const rawStatus = String(order.status || "pending").toLowerCase();

        const normalizedStatus =
          rawStatus === "paid" ? "paid" :
          (rawStatus === "cancelled" || rawStatus === "canceled") ? "canceled" :
          "pending";

        const statusClass = `status-${normalizedStatus}`;

        const items = Array.isArray(order.items) ? order.items : [];
        const total = items.reduce((sum, it) => {
          const price = Number(it.priceAtPurchase || 0);
          return sum + price;
        }, 0);

        const dateText = order.dateCreated
          ? new Date(order.dateCreated).toISOString().slice(0, 10)
          : (order.createdAt || "");
      %>

      <!-- IMPORTANT: data-orderid is what the modal JS reads -->
      <div class="order-card" data-orderid="<%= order.id %>">
        <div class="order-header">
          <div class="order-number">Order <%= order.id %></div>
          <div class="order-date"><%= dateText %></div>
        </div>

        <div class="order-total">$<%= total.toFixed(2) %></div>

        <div class="order-status <%= statusClass %>">
          <%= normalizedStatus %>
        </div>

        <div class="order-hint" style="opacity:.75; font-size:.9rem; margin-top:10px;">
          Click to view details
        </div>
      </div>

    <% }) %>
  <% } %>
</div>

<!-- ===== Order Detail Modal (same structure as admin page) ===== -->
<div id="orderModal" class="modal-overlay" style="display:none;">
  <div class="modal-content glass-panel" onclick="event.stopPropagation()">
    <div id="modalBody"></div>

    <div style="display:flex; justify-content:flex-end; margin-top:16px;">
      <button type="button" class="btn-close" onclick="closeModal()">Close</button>
    </div>
  </div>
</div>

<script src="/js/client/orderDetailModal.js"></script>

<script>
  // close when clicking outside modal card
  document.getElementById("orderModal")?.addEventListener("click", (e) => {
    if (e.target && e.target.id === "orderModal") closeModal();
  });

  // close with ESC
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<%- include("../partials/client-footer.ejs") %>