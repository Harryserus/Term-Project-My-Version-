<%- include("../partials/client-header.ejs", { title: "My Orders" }) %>

<!-- <div class="page-title">My Orders</div> -->

<div class="orders-container">
  <% if (!orders || orders.length === 0) { %>
    <div class="order-card">
      <div class="order-header">
        <div class="order-number">No orders yet</div>
        <div class="order-date">Buy a game to see it here.</div>
      </div>

      <a class="order-view-link" href="/customer">Go to store</a>
    </div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <%
        const rawStatus = String(order.status || "pending").toLowerCase();

        const normalizedStatus =
          rawStatus === "paid" ? "paid" :
          (rawStatus === "cancelled" || rawStatus === "canceled") ? "canceled" :
          "pending";

        const statusClass = `status-${normalizedStatus}`;

        const items = Array.isArray(order.items) ? order.items : [];
        const total = items.reduce((sum, it) => {
          const price = Number(it.priceAtPurchase || 0);
          return sum + price;
        }, 0);

        const dateText = order.dateCreated
          ? new Date(order.dateCreated).toISOString().slice(0, 10)
          : (order.createdAt || "");
      %>

      <div class="order-card">
        <div class="order-header">
          <div class="order-number">Order <%= order.id %></div>
          <div class="order-date"><%= dateText %></div>
        </div>

        <div class="order-price">$<%= total.toFixed(2) %></div>
        <div class="order-status <%= statusClass %>"><%= normalizedStatus %></div>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include("../partials/client-footer.ejs") %>