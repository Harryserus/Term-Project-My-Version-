<%- include("../partials/client-header.ejs") %>

<%
  // Safe defaults (won't crash even if not passed from controller)
  const currentSearch = typeof search === "string" ? search : "";
  const currentSort = typeof sort === "string" ? sort : "";
%>

<!-- <div class="page-title">Store</div> -->

<div class="categories-and-search">
  <div class="filter-container">
    <button class="category-button active all-filter-button" data-category="all">All</button>
    <button class="category-button status-pending" data-category="PC">PC</button>
    <button class="category-button status-paid" data-category="PS5">PS5</button>
    <button class="category-button status-delivered" data-category="Xbox">X-BOX</button>
    <button class="category-button status-canceled" data-category="Switch">SWITCH</button>
  </div>

  <div class="sort-container">
    
    <form id="sortForm" action="/customer" method="get" style="display:flex; gap:.75rem; align-items:center;">
      <span class="sort-label">Sort</span>
      <!-- keep search when sorting -->
      <input type="hidden" name="search-product" value="<%= currentSearch %>">

      <select id="sort-price" name="sort" class="sort-select" onchange="document.getElementById('sortForm').submit()">
        <option value="" <%= currentSort === "" ? "selected" : "" %>>Default</option>
        <option value="price_asc" <%= currentSort === "price_asc" ? "selected" : "" %>>Price: Low → High</option>
        <option value="price_desc" <%= currentSort === "price_desc" ? "selected" : "" %>>Price: High → Low</option>
      </select>
    </form>

    <div class="search-product-container">
      <form action="/customer" method="get" style="display:flex; align-items:center; gap:6px;">
        <!-- keep sort when searching -->
        <input type="hidden" name="sort" value="<%= currentSort %>">

        <input
          name="search-product"
          type="search"
          id="search-product"
          placeholder="Search"
          value="<%= currentSearch %>"
        />

        <button type="submit" id="search_product" class="search_button" aria-label="Search">
          <img src="/assets/search-icon.svg" alt="search" width="25px" />
        </button>
      </form>
    </div>
  </div>
</div>

<div class="products-container">
  <% if (typeof games !== "undefined" && games && games.length > 0) { %>
    <% games.forEach(game => { %>
      <a
        class="product-card"
        href="/customer/product/<%= game.id %>"
        data-platform="<%= (game.platforms || []).join(',') %>"
      >
        <img src="<%= game.thumbnailUrl %>" alt="<%= game.title %> thumbnail" />
        <div class="product-main-info">

          <div class="product-title-category">
            <h4><%= game.title %></h4>
            <p><%= (game.genres || []).join(", ") %></p>
          </div>
          <div class="product-actions">
            <p class="product-price">$<%= game.price %></p>
            <% if (game.availability === "coming_soon") { %>
              <span class="tag-pill subtle">Coming Soon</span>
            <% } else if (game.availability === "delisted") { %>
              <span class="tag-pill subtle">Delisted</span>
            <% } else if (game.stock === 0) { %>
              <span class="tag-pill subtle">Out of Stock</span>
            <% } else { %>
              <span class="tag-pill subtle">Available</span>
            <% } %>
          </div>
        </div>
      </a>
    <% }) %>
  <% } else { %>
    <div class="product-card" style="justify-content:center; text-align:center;">
      <div style="opacity:.9;">
        No games found.
        <% if (currentSearch) { %>
          <div style="opacity:.75; margin-top:.25rem;">Try a different keyword.</div>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<% if(alert) { %>
<script>
  alert('<%= alert %>')
  window.location.replace(window.location.pathname)
</script>
<% } %>

<%- include("../partials/client-footer.ejs") %>