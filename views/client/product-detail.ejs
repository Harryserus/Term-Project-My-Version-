<%- include("../partials/client-header.ejs", { title: "Game Detail" }) %>

<section class="page">

  <div class="product-detail">

    <div class="product-detail__image custom-card">
      <div class="image-placeholder">Game Image</div>
    </div>

    <div class="product-detail__info custom-card">

      <h1 class="product-detail__title">
        Indie Game Title
      </h1>

      <p class="product-detail__description">
        A beautifully crafted indie adventure game with immersive storytelling
        and unique gameplay mechanics.
      </p>

      <div class="product-detail__meta">
        <span class="tag">Action</span>
        <span class="tag">RPG</span>
        <span class="tag">Indie</span>
      </div>

      <div class="product-detail__price">
        $19.99
      </div>

      <div class="product-detail__actions">
        <button class="btn-primary">Add to Cart</button>
      </div>

    </div>

  </div>

</section>

<%- include("../partials/client-footer.ejs") %>