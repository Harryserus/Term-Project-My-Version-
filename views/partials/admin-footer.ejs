<style>
/*for toaster notification */
/* 1. SNAP-IN ANIMATION */
@keyframes slide-in-right {
  0% { transform: translateX(100%); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

@keyframes progress-drain {
  0% { width: 100%; }
  100% { width: 0%; }
}

/* 2. THE SOLID EMERALD CARD (No Blur) */
.glass-toast {
  position: fixed;
  top: 1.5rem;
  right: 1.5rem;
  z-index: 9999999;
  min-width: 280px;
  padding: 1rem;
  border-radius: 0.75rem;
  /* Solid colors for maximum performance */
  background: #064e3b; 
  border: 1px solid #10b981;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4);
  color: #ecfdf5;
  animation: slide-in-right 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  overflow: hidden;
  /* Fast 0.3s transition */
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.toast-error {
  background: #7f1d1d !important;
  border-color: #f43f5e !important;
}

.toast-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  height: 3px;
  background: #10b981;
  /* Matches the 1.5s stay-time in JS */
  animation: progress-drain 1.5s linear forwards;
}

.progress-error {
        background: #f43f5e !important;
      }

/* 3. THE EXIT STATE */
.toast-hidden {
  opacity: 0 !important;
  transform: translateX(30px);
}
</style>
